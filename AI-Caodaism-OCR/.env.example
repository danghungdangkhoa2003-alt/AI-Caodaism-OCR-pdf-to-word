# Optional: OpenRouter API for advanced OCR correction (not required for basic PDF→DOCX conversion)
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: Model selection for OCR correction
# Default: meta-llama/llama-2-70b-chat
OPENROUTER_MODEL=meta-llama/llama-2-70b-chat

# Optional: Processing settings
# Maximum confidence threshold for triggering review (0.0-1.0)
MIN_CONFIDENCE_THRESHOLD=0.7

# Number of CPU threads for parallel processing
MAX_WORKERS=4
